# ── Core ─────────────────────────────────────────────────────────────────────
APP_NAME=AgentShield Lite
DEBUG=false
DATABASE_URL=sqlite+aiosqlite:///./agentshield.db

# Optional API key — if set, all API routes require X-API-Key header
API_KEY=

# Risk threshold — actions with risk_score >= this trigger alerts (0-100)
RISK_ALERT_THRESHOLD=70

# ── Alert Channels (set any/all) ──────────────────────────────────────────────

# Slack incoming webhook
SLACK_WEBHOOK_URL=

# Microsoft Teams incoming webhook
TEAMS_WEBHOOK_URL=

# Email (SMTP) — requires: pip install aiosmtplib
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=agentshield@yourcompany.com
SMTP_TLS=true
ALERT_EMAIL_TO=security-team@yourcompany.com

# Generic webhooks — comma-separated URLs that receive JSON POST
WEBHOOK_URLS=

# ── CORS ─────────────────────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
